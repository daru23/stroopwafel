name: dutch-tracker

services:
  web:
    image: {{ tracker_web_image }}:{{ tracker_tag }}
    ports:
      # Bind to loopback only — host Caddy reverse-proxies stroopwafel.<domain>
      # to this port. Prevents direct external access on the raw port.
      - "127.0.0.1:{{ tracker_host_port }}:80"
    depends_on:
      - api
    restart: unless-stopped

  api:
    image: {{ tracker_api_image }}:{{ tracker_tag }}
    env_file: .env
    volumes:
      - tracker-data:/data
    restart: unless-stopped

volumes:
  tracker-data:
